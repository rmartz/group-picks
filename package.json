{
  "name": "firebase-nextjs-template",
  "version": "0.1.0",
  "description": "Template repository for Next.js projects built on Firebase",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "tsc": "tsc --noEmit",
    "lint": "eslint --max-warnings 0 .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky",
    "env:pull": "generate-local-env",
    "env:deploy": "scripts/deploy-config.sh",
    "env:validate": "node scripts/validate-config.mjs",
    "secrets-check": "pnpm run env:validate && secrets-check --config .gitleaks.toml"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,jsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored"
    ],
    "*.{js,mjs,cjs,ts,tsx,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "esbuild",
      "protobufjs",
      "vercel-deploy-scripts"
    ]
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@sentry/nextjs": "^10.50.0",
    "@tanstack/react-query": "^5.100.5",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-redux": "^9.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.3.5",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.5.0",
    "storybook": "^10.3.5",
    "tailwindcss": "^4",
    "typescript": "^6",
    "typescript-eslint": "^8.59.1",
    "vercel": "^52.0.0",
    "vercel-deploy-scripts": "github:rmartz/vercel-deploy-scripts#v1.7.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
